generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  administrator
  organization_admin
  admin_programming
  admin_english
  admin_osis_mpk
}

model User {
  id                  Int                   @id @default(autoincrement())
  nama                String                @db.VarChar(100)
  email               String                @unique @db.VarChar(150)
  password            String                @db.VarChar(255)
  role                Role                  @default(ORG_ADMIN)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt
  last_seen_update_id Int?
  
  // Relations
  organizations       OrganizationAdmin[]
  log_aktivitas       LogAktivitas[]
  documentations      Documentation[]       @relation("DocCreatedBy")
  dokumentasi_foto    DokumentasiFoto[]     @relation("FotoCreatedBy")
  email_logs          EmailLog[]            @relation("AdminEmailLogs")
  email_import_logs   EmailImportLog[]      @relation("AdminImportLogs")
  updates_created     SystemUpdate[]        @relation("UpdateCreatedBy")
  exp_logs_given      ExpLog[]
  
  @@index([created_at])
  @@map("users")
}

model Organization {
  id                     Int                   @id @default(autoincrement())
  nama                   String                @db.VarChar(100)
  slug                   String                @unique @db.VarChar(100)
  category               String                @db.VarChar(50) @default("Ekstrakurikuler")
  school_origin          String                @db.VarChar(100) @default("SMK Airlangga")
  status                 String                @db.VarChar(20) @default("Aktif")
  deskripsi              String?
  hari_pertemuan         String?               @db.VarChar(20)
  lokasi                 String?               @db.VarChar(100)
  waktu_mulai            String?               @db.VarChar(10)
  waktu_selesai          String?               @db.VarChar(10)
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  
  // Relations
  admins                 OrganizationAdmin[]
  members                Member[]
  attendance             Attendance[]
  cash_transactions      CashTransaction[]
  cash_expenses          CashExpense[]
  registrations          Registration[]
  documentations         Documentation[]
  dokumentasi_foto       DokumentasiFoto[]
  announcements          Announcement[]
  materials              Material[]
  schedules              Schedule[]
  email_templates        EmailTemplate[]
  exp_logs               ExpLog[]
  achievements           Achievement[]

  @@map("organizations")
}

model OrganizationAdmin {
  id              Int          @id @default(autoincrement())
  user_id         Int
  organization_id Int
  created_at      DateTime     @default(now())
  
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([user_id, organization_id])
  @@map("organization_admins")
}

model Member {
  id              Int          @id @default(autoincrement())
  organization_id Int
  nis             String?      @db.VarChar(20)
  name            String       @db.VarChar(100)
  email           String?      @db.VarChar(150)
  class           String?      @db.VarChar(20)
  jabatan         String?      @db.VarChar(100) @default("Anggota")
  level           Int          @default(1)
  exp             Int          @default(0)
  status          String       @default("ACTIVE") @db.VarChar(20)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  attendance      Attendance[]
  cash_transactions CashTransaction[]
  exp_logs        ExpLog[]
  achievements    MemberAchievement[]

  @@index([organization_id])
  @@index([nis])
  @@index([name])
  @@map("members")
}

model Attendance {
  id                Int          @id @default(autoincrement())
  organization_id   Int
  member_id         Int
  date              DateTime     @db.Date
  status            String       @db.VarChar(20) // hadir, izin, sakit, alpa
  cash_amount       Int          @default(0)
  notes             String?      @db.Text
  created_at        DateTime     @default(now())
  
  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  member            Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([member_id, date])
  @@index([organization_id])
  @@index([date])
  @@map("attendance")
}

model CashTransaction {
  id              Int          @id @default(autoincrement())
  organization_id Int
  member_id       Int
  amount          Int
  type            String       @default("INCOME") @db.VarChar(10) // INCOME, EXPENSE
  description     String       @db.VarChar(255)
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  member          Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([member_id])
  @@map("cash_transactions")
}

model CashExpense {
  id              Int          @id @default(autoincrement())
  organization_id Int
  amount          Int
  description     String       @db.VarChar(255)
  date            DateTime     @default(now())
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("cash_expenses")
}

model Registration {
  id               Int                @id @default(autoincrement())
  organization_id  Int
  name             String             @db.VarChar(100)
  class            String             @db.VarChar(50)
  major            String             @db.VarChar(100)
  email            String             @db.VarChar(100)
  nisn             String?            @db.VarChar(20)
  status           RegistrationStatus @default(MENUNGGU)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  
  organization     Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([email, organization_id])
  @@index([organization_id])
  @@index([status])
  @@map("registrations")
}

model LogAktivitas {
  id              Int          @id @default(autoincrement())
  user_id         Int
  organization_id Int?
  user_nama       String       @db.VarChar(100)
  aksi            AksiLog
  tabel           String       @db.VarChar(50)
  record_id       String?      @db.VarChar(50)
  deskripsi       String
  data_lama       Json?
  data_baru       Json?
  ip_address      String?      @db.VarChar(45)
  created_at      DateTime     @default(now())
  
  user            User         @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([organization_id])
  @@index([created_at])
  @@map("log_aktivitas")
}

model Documentation {
  id             Int            @id @default(autoincrement())
  organization_id Int
  title          String         @db.VarChar(200)
  description    String?
  category       String         @db.VarChar(100)
  created_by     Int
  date_taken     DateTime       @default(now())
  photos         Json
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  
  organization   Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  creator        User           @relation("DocCreatedBy", fields: [created_by], references: [id])

  @@index([organization_id])
  @@map("documentations")
}

model DokumentasiFoto {
  id              Int            @id @default(autoincrement())
  organization_id Int
  judul           String         @db.VarChar(150)
  description     String?
  image_url       String         @db.VarChar(255)
  public_id       String?        @db.VarChar(100)
  tanggal         DateTime       @db.Date
  created_by      Int
  created_at      DateTime       @default(now())
  
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  creator         User           @relation("FotoCreatedBy", fields: [created_by], references: [id])

  @@index([organization_id])
  @@map("dokumentasi_foto")
}

model Announcement {
  id              Int          @id @default(autoincrement())
  organization_id Int
  title           String       @db.VarChar(255)
  content         String       @db.Text
  is_active       Boolean      @default(true)
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("announcements")
}

model Material {
  id              Int          @id @default(autoincrement())
  organization_id Int
  title           String       @db.VarChar(255)
  content         String       @db.Text
  date            DateTime     @db.Date
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("materials")
}

model Schedule {
  id              Int          @id @default(autoincrement())
  organization_id Int
  title           String       @db.VarChar(255)
  date            DateTime     @db.Date
  start_time      String?      @db.VarChar(10)
  location        String?      @db.VarChar(200)
  is_mandatory    Boolean      @default(false)
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@map("schedules")
}

model EmailTemplate {
  id               Int            @id @default(autoincrement())
  organization_id  Int
  email_type       String         @db.VarChar(50)
  subject          String
  body_template    String
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())
  
  organization     Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, email_type])
  @@map("email_templates")
}

model ExpLog {
  id              Int          @id @default(autoincrement())
  member_id       Int
  organization_id Int
  admin_id        Int
  exp_before      Int
  exp_after       Int
  amount          Int
  reason          String       @db.VarChar(500)
  created_at      DateTime     @default(now())
  
  member          Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  admin           User         @relation(fields: [admin_id], references: [id])

  @@index([member_id])
  @@index([organization_id])
  @@index([created_at])
  @@map("exp_logs")
}

model Achievement {
  id              Int          @id @default(autoincrement())
  organization_id Int
  icon            String       @db.VarChar(100)
  name            String       @db.VarChar(150)
  description     String       @db.Text
  exp_reward      Int
  created_at      DateTime     @default(now())
  
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  members         MemberAchievement[]

  @@index([organization_id])
  @@map("achievements")
}

model MemberAchievement {
  id              Int          @id @default(autoincrement())
  member_id       Int
  achievement_id  Int
  earned_at       DateTime     @default(now())
  
  member          Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)
  achievement     Achievement  @relation(fields: [achievement_id], references: [id], onDelete: Cascade)

  @@unique([member_id, achievement_id])
  @@map("member_achievements")
}
model MasterKelas {
  id            Int      @id @default(autoincrement())
  kelas_nama    String   @unique @db.VarChar(10)
  kelas_singkat String   @db.VarChar(5)
  tingkat       String?  @db.VarChar(20)
  created_at    DateTime @default(now())

  @@map("master_kelas")
}

model MasterKejuruan {
  id               Int        @id @default(autoincrement())
  kejuruan_kode    String     @unique @db.VarChar(20)
  kejuruan_nama    String     @db.VarChar(100)
  kejuruan_singkat String     @db.VarChar(20)
  skill_group      SkillGroup
  created_at       DateTime   @default(now())

  @@map("master_kejuruan")
}

model SystemUpdate {
  id          Int        @id @default(autoincrement())
  version     String     @db.VarChar(50)
  content     String
  update_type UpdateType @default(update)
  created_at  DateTime   @default(now())
  created_by  Int
  creator     User       @relation("UpdateCreatedBy", fields: [created_by], references: [id])

  @@index([created_at])
  @@map("system_updates")
}

model EmailLog {
  id               Int            @id @default(autoincrement())
  subject          String         @db.VarChar(255)
  recipient_email  String         @db.VarChar(150)
  recipient_name   String         @db.VarChar(100)
  content          String
  admin_id         Int
  status           String         @default("sent") @db.VarChar(20)
  error_message    String?
  sent_at          DateTime?
  created_at       DateTime       @default(now())
  admin            User           @relation("AdminEmailLogs", fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@map("email_logs")
}

model EmailImportLog {
  id               Int            @id @default(autoincrement())
  filename         String         @db.VarChar(255)
  total_rows       Int
  success_rows     Int
  failure_rows     Int
  admin_id         Int
  errors           String
  status           String         @default("completed") @db.VarChar(20)
  created_at       DateTime       @default(now())
  admin            User           @relation("AdminImportLogs", fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@map("email_import_logs")
}

model EmailSetting {
  id           Int      @id @default(autoincrement())
  email        String   @db.VarChar(150)
  app_password String   @db.VarChar(255)
  updated_at   DateTime @updatedAt

  @@map("email_settings")
}

// Enums

enum RegistrationStatus {
  MENUNGGU
  DITERIMA
  DITOLAK
  CALON
}

enum SkillGroup {
  SKARLA
  SKAKES
}

enum AksiLog {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum UpdateType {
  update
  pengumuman
  perbaikan
}
