generator client {
  provider = "prisma-client-js"
  // Aktifkan output yang lebih kecil untuk production
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  administrator
  admin_programming
  admin_english
  admin_osis_mpk
}

enum OrganisasiType {
  programming
  english
  osis
  mpk
}

enum StatusAbsensi {
  hadir
  tidak_hadir
  izin
  sakit
  kas_saja
}

enum AksiLog {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum StatusWawancara {
  SCHEDULED
  ACTIVE
  SELESAI
  DIBATALKAN
}

enum StatusAntrian {
  MENUNGGU
  WAWANCARA
  SELESAI_WAWANCARA
}

enum StatusValidasiScan {
  SAH
  SAH_DICURIGAI
  DITOLAK_VPN
  TIDAK_SAH
}

enum StatusIpScan {
  NORMAL
  VPN_INDONESIA
  VPN_LUAR_NEGERI
  TIDAK_DIKETAHUI
}

enum HasilWawancara {
  DITERIMA
  DITOLAK
  DIPERTIMBANGKAN
  LOLOS
  TIDAK_LOLOS
  PENDING
}

enum KeteranganWawancara {
  AKTIF
  KURANG_AKTIF
}

enum UpdateType {
  update
  pengumuman
  perbaikan
}

enum TipeAnggota {
  siswa
  anggota_osis
  anggota_mpk
}

// ============================================================
// TABLE: users
// ============================================================
model User {
  id         Int      @id @default(autoincrement())
  nama       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(150)
  password   String   @db.VarChar(255)
  role       Role
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  absensi_dibuat  Absensi[]       @relation("AbsensiCreatedBy")
  absensi_diubah  Absensi[]       @relation("AbsensiUpdatedBy")
  siswa_dibuat    Siswa[]         @relation("SiswaCreatedBy")
  log_aktivitas   LogAktivitas[]
  pengeluaran_kas PengeluaranKas[]
  sesi_wawancara  SesiWawancara[]
  qr_wawancara    QrWawancara[]
  penilaian_wawancara HasilWawancaraTable[] @relation("WawancaraAssessedBy")
  override_wawancara HasilWawancaraTable[] @relation("WawancaraOverriddenBy")
  chat_wawancara ChatWawancara[]

  last_seen_update_id Int?
  updates_created     SystemUpdate[] @relation("UpdateCreatedBy")
  dokumentasi_foto    DokumentasiFoto[] @relation("FotoCreatedBy")

  @@index([created_at])
  @@map("users")
}

// ============================================================
// TABLE: siswa (untuk ekskul)
// ============================================================
model Siswa {
  id          Int            @id @default(autoincrement())
  nis         String?        @db.VarChar(20)
  nama        String         @db.VarChar(100)
  kelas       String?        @db.VarChar(20)
  email       String?        @db.VarChar(150)
  foto_url    String?        @db.VarChar(255)
  ekskul      OrganisasiType
  jabatan     String?        @db.VarChar(100)
  xp          Int            @default(0)
  level       Int            @default(1)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  created_by  Int
  creator     User           @relation("SiswaCreatedBy", fields: [created_by], references: [id])

  // Relations
  absensi     Absensi[]
  pencapaian  SiswaPencapaian[]

  @@index([ekskul])
  @@index([xp])
  @@index([level])
  @@index([nama])
  @@index([kelas])
  @@index([created_at])
  @@map("siswa")
}

// ============================================================
// TABLE: absensi (untuk ekskul: programming & english)
// ============================================================
model Absensi {
  id           Int           @id @default(autoincrement())
  siswa_id     Int
  tanggal      DateTime      @db.Date
  status       StatusAbsensi @default(hadir)
  uang_kas     Int           @default(0)
  keterangan   String?       @db.VarChar(200)
  created_by   Int
  updated_by   Int?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  // Relations
  siswa        Siswa         @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  creator      User          @relation("AbsensiCreatedBy", fields: [created_by], references: [id])
  updater      User?         @relation("AbsensiUpdatedBy", fields: [updated_by], references: [id])

  @@unique([siswa_id, tanggal])
  @@index([tanggal])
  @@index([siswa_id])
  @@map("absensi")
}

// ============================================================
// TABLE: anggota_osis (OSIS - dipisah dari MPK)
// ============================================================
model AnggotaOsis {
  id         Int      @id @default(autoincrement())
  nis        String?  @db.VarChar(20)
  nama       String   @db.VarChar(100)
  kelas      String?  @db.VarChar(20)
  email      String?  @db.VarChar(150)
  foto_url   String?  @db.VarChar(255)
  jabatan    String?  @db.VarChar(100)
  xp         Int      @default(0)
  level      Int      @default(1)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  absensi        AbsensiOrganisasi[]
  pencapaian     SiswaPencapaian[]

  @@index([nama])
  @@index([kelas])
  @@index([xp])
  @@index([created_at])
  @@map("anggota_osis")
}

// ============================================================
// TABLE: anggota_mpk (MPK - dipisah dari OSIS)
// ============================================================
model AnggotaMpk {
  id         Int      @id @default(autoincrement())
  nis        String?  @db.VarChar(20)
  nama       String   @db.VarChar(100)
  kelas      String?  @db.VarChar(20)
  email      String?  @db.VarChar(150)
  foto_url   String?  @db.VarChar(255)
  jabatan    String?  @db.VarChar(100)
  xp         Int      @default(0)
  level      Int      @default(1)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  absensi        AbsensiOrganisasi[]
  pencapaian     SiswaPencapaian[]

  @@index([nama])
  @@index([kelas])
  @@index([xp])
  @@index([created_at])
  @@map("anggota_mpk")
}

// ============================================================
// TABLE: absensi_organisasi (untuk OSIS & MPK)
// Polymorphic: organisasi_type menentukan OSIS atau MPK
// ============================================================
model AbsensiOrganisasi {
  id               Int            @id @default(autoincrement())
  organisasi_type  OrganisasiType // 'osis' atau 'mpk'
  anggota_osis_id  Int?
  anggota_mpk_id   Int?
  tanggal          DateTime       @db.Date
  status           StatusAbsensi  @default(hadir)
  uang_kas         Int            @default(0)
  keterangan       String?        @db.VarChar(200)
  created_by       Int
  updated_by       Int?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  // Relations
  anggota_osis     AnggotaOsis?   @relation(fields: [anggota_osis_id], references: [id], onDelete: Cascade)
  anggota_mpk      AnggotaMpk?    @relation(fields: [anggota_mpk_id], references: [id], onDelete: Cascade)

  @@unique([anggota_osis_id, tanggal])
  @@unique([anggota_mpk_id, tanggal])
  @@index([tanggal])
  @@index([organisasi_type])
  @@map("absensi_organisasi")
}

// ============================================================
// TABLE: log_aktivitas (audit trail)
// ============================================================
model LogAktivitas {
  id            Int      @id @default(autoincrement())
  user_id       Int
  user_nama     String   @db.VarChar(100)
  aksi          AksiLog
  tabel         String   @db.VarChar(50)
  record_id     String?  @db.VarChar(50)
  deskripsi     String   @db.Text
  data_lama     Json?
  data_baru     Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now())

  // Relations
  user          User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([tabel])
  @@index([created_at])
  @@map("log_aktivitas")
}

// ============================================================
// TABLE: pengeluaran_kas (tarik kas organisasi)
// ============================================================
model PengeluaranKas {
  id              Int            @id @default(autoincrement())
  organisasi_type OrganisasiType
  nominal         Int
  keterangan      String         @db.VarChar(255)
  tanggal         DateTime       @default(now())
  created_by      Int
  created_at      DateTime       @default(now())

  // Relations
  creator         User           @relation(fields: [created_by], references: [id])

  @@index([organisasi_type])
  @@index([tanggal])
  @@map("pengeluaran_kas")
}

// ============================================================
// TABLE: sesi_wawancara (kontrol dari Super Admin)
// ============================================================
model SesiWawancara {
  id              Int             @id @default(autoincrement())
  organisasi_type OrganisasiType  // osis atau mpk
  status          StatusWawancara @default(SCHEDULED)
  jadwal_mulai    DateTime?
  jadwal_selesai  DateTime?
  finalized_at    DateTime?
  locked_at       DateTime?
  created_by      Int
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  // Relations
  creator         User               @relation(fields: [created_by], references: [id])
  antrian         AntrianWawancara[]
  chat            ChatWawancara[]
  qr_codes        QrWawancara[]

  @@index([organisasi_type])
  @@index([status])
  @@map("sesi_wawancara")
}

// ============================================================
// TABLE: antrian_wawancara (peserta scan QR)
// ============================================================
model AntrianWawancara {
  id              Int            @id @default(autoincrement())
  sesi_id         Int
  qr_id           Int?
  nama            String         @db.VarChar(50)
  kelas           String         @db.VarChar(20)
  nomor_antrian   Int
  status          StatusAntrian  @default(MENUNGGU)
  scan_token      String?        @db.VarChar(80)
  ip_address      String?        @db.VarChar(45)
  ip_country      String?        @db.VarChar(80)
  ip_isp          String?        @db.VarChar(150)
  ip_status       StatusIpScan   @default(TIDAK_DIKETAHUI)
  gps_lat         Float?
  gps_lng         Float?
  jarak_meter     Float?
  status_validasi StatusValidasiScan @default(SAH)
  alasan_validasi String?        @db.VarChar(255)
  user_agent      String?        @db.VarChar(255)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  // Relations
  sesi            SesiWawancara   @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  qr              QrWawancara?    @relation(fields: [qr_id], references: [id])
  hasil_wawancara HasilWawancaraTable?

  @@unique([sesi_id, nomor_antrian])
  @@index([qr_id])
  @@index([status_validasi])
  @@index([scan_token])
  @@index([sesi_id, status_validasi, kelas])
  @@index([sesi_id, nama, kelas])
  @@index([created_at])
  @@map("antrian_wawancara")
}

// ============================================================
// TABLE: qr_wawancara (token QR absensi wawancara)
// ============================================================
model QrWawancara {
  id          Int      @id @default(autoincrement())
  sesi_id     Int
  token       String   @unique @db.VarChar(80)
  aktif       Boolean  @default(true)
  valid_from  DateTime @default(now())
  valid_until DateTime
  created_by  Int
  created_at  DateTime @default(now())

  sesi        SesiWawancara @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  creator     User          @relation(fields: [created_by], references: [id])
  antrian     AntrianWawancara[]

  @@index([sesi_id])
  @@index([valid_until])
  @@map("qr_wawancara")
}

// ============================================================
// TABLE: hasil_wawancara (penilaian)
// ============================================================
model HasilWawancaraTable {
  id             Int            @id @default(autoincrement())
  antrian_id     Int            @unique
  interviewer_id Int
  override_by    Int?
  keterangan     KeteranganWawancara
  hasil          HasilWawancara
  persentase     Float
  catatan        String?        @db.Text
  override_alasan String?       @db.Text
  override_at    DateTime?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  // Relations
  antrian        AntrianWawancara @relation(fields: [antrian_id], references: [id], onDelete: Cascade)
  interviewer    User             @relation("WawancaraAssessedBy", fields: [interviewer_id], references: [id])
  overrider      User?            @relation("WawancaraOverriddenBy", fields: [override_by], references: [id])

  @@map("hasil_wawancara")
  @@index([interviewer_id])
  @@index([hasil])
  @@index([created_at])
}

// ============================================================
// TABLE: chat_wawancara (live chat internal saat sesi aktif)
// ============================================================
model ChatWawancara {
  id         Int      @id @default(autoincrement())
  sesi_id    Int
  sender_id  Int
  pesan      String   @db.Text
  created_at DateTime @default(now())

  sesi       SesiWawancara @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [sender_id], references: [id])

  @@index([sesi_id])
  @@index([sesi_id, created_at])
  @@index([created_at])
  @@map("chat_wawancara")
}

// ============================================================
// TABLE: system_updates (notifikasi pembaruan)
// ============================================================
model SystemUpdate {
  id          Int        @id @default(autoincrement())
  version     String     @db.VarChar(50)
  content     String     @db.Text
  update_type UpdateType @default(update)
  created_at  DateTime   @default(now())
  created_by  Int

  // Relations
  creator     User       @relation("UpdateCreatedBy", fields: [created_by], references: [id])

  @@map("system_updates")
  @@index([created_at])
  @@index([update_type])
}

// ============================================================
// TABLE: dokumentasi_foto (dokumentasi foto kegiatan admin)
// ============================================================
model DokumentasiFoto {
  id              Int            @id @default(autoincrement())
  organisasi_type OrganisasiType
  judul           String         @db.VarChar(150)
  deskripsi       String?        @db.Text
  image_url       String         @db.VarChar(255)
  public_id       String?        @db.VarChar(100)
  tanggal         DateTime       @db.Date
  created_by      Int
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  creator         User           @relation("FotoCreatedBy", fields: [created_by], references: [id])

  @@map("dokumentasi_foto")
  @@index([organisasi_type])
  @@index([tanggal])
  @@index([created_at])
}

// ============================================================
// TABLE: pencapaian (master data achievement)
// ============================================================
model Pencapaian {
  id           Int      @id @default(autoincrement())
  icon         String   @db.VarChar(100)
  nama         String   @db.VarChar(150)
  deskripsi    String   @db.Text
  exp_reward   Int
  organisasi   String   @db.VarChar(20)
  created_at   DateTime @default(now())

  penerima     SiswaPencapaian[]

  @@index([organisasi])
  @@map("pencapaian")
}

// ============================================================
// TABLE: siswa_pencapaian (polymorphic junction)
// Berlaku untuk: siswa ekskul, anggota_osis, anggota_mpk
// ============================================================
model SiswaPencapaian {
  id             Int          @id @default(autoincrement())
  pencapaian_id  Int
  tipe_anggota   TipeAnggota
  siswa_id       Int?         // FK → siswa.id
  anggota_osis_id Int?        // FK → anggota_osis.id
  anggota_mpk_id Int?         // FK → anggota_mpk.id
  tanggal        DateTime     @default(now())

  pencapaian     Pencapaian   @relation(fields: [pencapaian_id], references: [id], onDelete: Cascade)
  siswa          Siswa?       @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  anggota_osis   AnggotaOsis? @relation(fields: [anggota_osis_id], references: [id], onDelete: Cascade)
  anggota_mpk    AnggotaMpk?  @relation(fields: [anggota_mpk_id], references: [id], onDelete: Cascade)

  @@unique([pencapaian_id, siswa_id])
  @@unique([pencapaian_id, anggota_osis_id])
  @@unique([pencapaian_id, anggota_mpk_id])
  @@index([pencapaian_id])
  @@index([tipe_anggota])
  @@map("siswa_pencapaian")
}

// ============================================================
// TABLE: materi_hari_ini
// Untuk ekskul: materi pelajaran. Untuk OSIS/MPK: notulen rapat
// ============================================================
model MateriHariIni {
  id          Int            @id @default(autoincrement())
  judul       String         @db.VarChar(255)
  deskripsi   String         @db.Text
  tanggal     DateTime       @db.Date
  organisasi  OrganisasiType
  // Extra fields untuk OSIS/MPK
  notulen     String?        @db.Text
  lokasi      String?        @db.VarChar(200)
  created_by  Int
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([organisasi])
  @@index([tanggal])
  @@map("materi_hari_ini")
}

// ============================================================
// TABLE: jadwal_kegiatan
// Untuk ekskul: jadwal pengajar. Untuk OSIS/MPK: jadwal rapat
// ============================================================
model JadwalKegiatan {
  id            Int            @id @default(autoincrement())
  judul         String         @db.VarChar(255)
  tanggal       DateTime       @db.Date
  waktu         String?        @db.VarChar(10)
  lokasi        String?        @db.VarChar(200)
  keterangan    String?        @db.Text
  organisasi    OrganisasiType
  wajib_hadir   Boolean        @default(false)
  created_by    Int
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  @@index([organisasi])
  @@index([tanggal])
  @@map("jadwal_kegiatan")
}

// ============================================================
// TABLE: exp_log (audit trail semua perubahan EXP)
// ============================================================
model ExpLog {
  id            Int          @id @default(autoincrement())
  tipe_anggota  TipeAnggota
  siswa_id      Int?
  anggota_osis_id Int?
  anggota_mpk_id  Int?
  admin_id      Int
  exp_sebelum   Int
  exp_sesudah   Int
  selisih       Int
  alasan        String       @db.VarChar(500)
  organisasi    String       @db.VarChar(20)
  created_at    DateTime     @default(now())

  @@index([tipe_anggota])
  @@index([siswa_id])
  @@index([anggota_osis_id])
  @@index([anggota_mpk_id])
  @@index([admin_id])
  @@index([created_at])
  @@map("exp_log")
}
