generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                   @id @default(autoincrement())
  nama                String                @db.VarChar(100)
  email               String                @unique @db.VarChar(150)
  password            String                @db.VarChar(255)
  role                Role
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt
  last_seen_update_id Int?
  absensi_dibuat      Absensi[]             @relation("AbsensiCreatedBy")
  absensi_diubah      Absensi[]             @relation("AbsensiUpdatedBy")
  chat_wawancara      ChatWawancara[]
  dokumentasi_foto    DokumentasiFoto[]     @relation("FotoCreatedBy")
  penilaian_wawancara HasilWawancaraTable[] @relation("WawancaraAssessedBy")
  override_wawancara  HasilWawancaraTable[] @relation("WawancaraOverriddenBy")
  log_aktivitas       LogAktivitas[]
  pengeluaran_kas     PengeluaranKas[]
  qr_wawancara        QrWawancara[]
  sesi_wawancara      SesiWawancara[]
  siswa_dibuat        Siswa[]               @relation("SiswaCreatedBy")
  updates_created     SystemUpdate[]        @relation("UpdateCreatedBy")
  email_logs          EmailLog[]            @relation("AdminEmailLogs")
  email_import_logs   EmailImportLog[]      @relation("AdminImportLogs")

  @@index([created_at])
  @@map("users")
}

model Siswa {
  id         Int               @id @default(autoincrement())
  nis        String?           @db.VarChar(20)
  nama       String            @db.VarChar(100)
  kelas      String?           @db.VarChar(20)
  email      String?           @db.VarChar(150)
  foto_url   String?           @db.VarChar(255)
  ekskul     OrganisasiType
  jabatan    String?           @db.VarChar(100)
  xp         Int               @default(0)
  level      Int               @default(1)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  created_by Int
  absensi    Absensi[]
  creator    User              @relation("SiswaCreatedBy", fields: [created_by], references: [id])
  pencapaian SiswaPencapaian[]
  email_logs EmailLog[]        @relation("SiswaEmailLogs")

  @@index([ekskul])
  @@index([xp])
  @@index([level])
  @@index([nama])
  @@index([kelas])
  @@index([created_at])
  @@map("siswa")
}

model Absensi {
  id         Int           @id @default(autoincrement())
  siswa_id   Int
  tanggal    DateTime      @db.Date
  status     StatusAbsensi @default(hadir)
  uang_kas   Int           @default(0)
  keterangan String?       @db.VarChar(200)
  created_by Int
  updated_by Int?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  creator    User          @relation("AbsensiCreatedBy", fields: [created_by], references: [id])
  siswa      Siswa         @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  updater    User?         @relation("AbsensiUpdatedBy", fields: [updated_by], references: [id])

  @@unique([siswa_id, tanggal])
  @@index([tanggal])
  @@index([siswa_id])
  @@map("absensi")
}

model AnggotaOsis {
  id         Int                 @id @default(autoincrement())
  nis        String?             @db.VarChar(20)
  nama       String              @db.VarChar(100)
  kelas      String?             @db.VarChar(20)
  email      String?             @db.VarChar(150)
  foto_url   String?             @db.VarChar(255)
  jabatan    String?             @db.VarChar(100)
  xp         Int                 @default(0)
  level      Int                 @default(1)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  absensi    AbsensiOrganisasi[]
  pencapaian SiswaPencapaian[]
  email_logs EmailLog[]          @relation("OsisEmailLogs")

  @@index([nama])
  @@index([kelas])
  @@index([xp])
  @@index([created_at])
  @@map("anggota_osis")
}

model AnggotaMpk {
  id         Int                 @id @default(autoincrement())
  nis        String?             @db.VarChar(20)
  nama       String              @db.VarChar(100)
  kelas      String?             @db.VarChar(20)
  email      String?             @db.VarChar(150)
  foto_url   String?             @db.VarChar(255)
  jabatan    String?             @db.VarChar(100)
  xp         Int                 @default(0)
  level      Int                 @default(1)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  absensi    AbsensiOrganisasi[]
  pencapaian SiswaPencapaian[]
  email_logs EmailLog[]          @relation("MpkEmailLogs")

  @@index([nama])
  @@index([kelas])
  @@index([xp])
  @@index([created_at])
  @@map("anggota_mpk")
}

model AbsensiOrganisasi {
  id              Int            @id @default(autoincrement())
  organisasi_type OrganisasiType
  anggota_osis_id Int?
  anggota_mpk_id  Int?
  tanggal         DateTime       @db.Date
  status          StatusAbsensi  @default(hadir)
  uang_kas        Int            @default(0)
  keterangan      String?        @db.VarChar(200)
  created_by      Int
  updated_by      Int?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  anggota_mpk     AnggotaMpk?    @relation(fields: [anggota_mpk_id], references: [id], onDelete: Cascade)
  anggota_osis    AnggotaOsis?   @relation(fields: [anggota_osis_id], references: [id], onDelete: Cascade)

  @@unique([anggota_osis_id, tanggal])
  @@unique([anggota_mpk_id, tanggal])
  @@index([tanggal])
  @@index([organisasi_type])
  @@map("absensi_organisasi")
}

model LogAktivitas {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user_nama  String   @db.VarChar(100)
  aksi       AksiLog
  tabel      String   @db.VarChar(50)
  record_id  String?  @db.VarChar(50)
  deskripsi  String
  data_lama  Json?
  data_baru  Json?
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([tabel])
  @@index([created_at])
  @@map("log_aktivitas")
}

model PengeluaranKas {
  id              Int            @id @default(autoincrement())
  organisasi_type OrganisasiType
  nominal         Int
  keterangan      String         @db.VarChar(255)
  tanggal         DateTime       @default(now())
  created_by      Int
  created_at      DateTime       @default(now())
  creator         User           @relation(fields: [created_by], references: [id])

  @@index([organisasi_type])
  @@index([tanggal])
  @@map("pengeluaran_kas")
}

model SesiWawancara {
  id              Int                @id @default(autoincrement())
  organisasi_type OrganisasiType
  status          StatusWawancara    @default(SCHEDULED)
  jadwal_mulai    DateTime?
  jadwal_selesai  DateTime?
  finalized_at    DateTime?
  locked_at       DateTime?
  created_by      Int
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  antrian         AntrianWawancara[]
  chat            ChatWawancara[]
  qr_codes        QrWawancara[]
  creator         User               @relation(fields: [created_by], references: [id])

  @@index([organisasi_type])
  @@index([status])
  @@map("sesi_wawancara")
}

model AntrianWawancara {
  id              Int                  @id @default(autoincrement())
  sesi_id         Int
  qr_id           Int?
  nama            String               @db.VarChar(50)
  kelas           String               @db.VarChar(20)
  nomor_antrian   Int
  status          StatusAntrian        @default(MENUNGGU)
  scan_token      String?              @db.VarChar(80)
  ip_address      String?              @db.VarChar(45)
  ip_country      String?              @db.VarChar(80)
  ip_isp          String?              @db.VarChar(150)
  ip_status       StatusIpScan         @default(TIDAK_DIKETAHUI)
  gps_lat         Float?
  gps_lng         Float?
  jarak_meter     Float?
  status_validasi StatusValidasiScan   @default(SAH)
  alasan_validasi String?              @db.VarChar(255)
  user_agent      String?              @db.VarChar(255)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  qr              QrWawancara?         @relation(fields: [qr_id], references: [id])
  sesi            SesiWawancara        @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  hasil_wawancara HasilWawancaraTable?

  @@unique([sesi_id, nomor_antrian])
  @@index([qr_id])
  @@index([status_validasi])
  @@index([scan_token])
  @@index([sesi_id, status_validasi, kelas])
  @@index([sesi_id, nama, kelas])
  @@index([created_at])
  @@map("antrian_wawancara")
}

model QrWawancara {
  id          Int                @id @default(autoincrement())
  sesi_id     Int
  token       String             @unique @db.VarChar(80)
  aktif       Boolean            @default(true)
  valid_from  DateTime           @default(now())
  valid_until DateTime
  created_by  Int
  created_at  DateTime           @default(now())
  antrian     AntrianWawancara[]
  creator     User               @relation(fields: [created_by], references: [id])
  sesi        SesiWawancara      @relation(fields: [sesi_id], references: [id], onDelete: Cascade)

  @@index([sesi_id])
  @@index([valid_until])
  @@map("qr_wawancara")
}

model HasilWawancaraTable {
  id              Int                 @id @default(autoincrement())
  antrian_id      Int                 @unique
  interviewer_id  Int
  override_by     Int?
  keterangan      KeteranganWawancara
  hasil           HasilWawancara
  persentase      Float
  catatan         String?
  override_alasan String?
  override_at     DateTime?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  antrian         AntrianWawancara    @relation(fields: [antrian_id], references: [id], onDelete: Cascade)
  interviewer     User                @relation("WawancaraAssessedBy", fields: [interviewer_id], references: [id])
  overrider       User?               @relation("WawancaraOverriddenBy", fields: [override_by], references: [id])

  @@index([interviewer_id])
  @@index([hasil])
  @@index([created_at])
  @@map("hasil_wawancara")
}

model ChatWawancara {
  id         Int           @id @default(autoincrement())
  sesi_id    Int
  sender_id  Int
  pesan      String
  created_at DateTime      @default(now())
  sender     User          @relation(fields: [sender_id], references: [id])
  sesi       SesiWawancara @relation(fields: [sesi_id], references: [id], onDelete: Cascade)

  @@index([sesi_id])
  @@index([sesi_id, created_at])
  @@index([created_at])
  @@map("chat_wawancara")
}

model SystemUpdate {
  id          Int        @id @default(autoincrement())
  version     String     @db.VarChar(50)
  content     String
  update_type UpdateType @default(update)
  created_at  DateTime   @default(now())
  created_by  Int
  creator     User       @relation("UpdateCreatedBy", fields: [created_by], references: [id])

  @@index([created_at])
  @@index([update_type])
  @@map("system_updates")
}

model DokumentasiFoto {
  id              Int            @id @default(autoincrement())
  organisasi_type OrganisasiType
  judul           String         @db.VarChar(150)
  deskripsi       String?
  image_url       String         @db.VarChar(255)
  public_id       String?        @db.VarChar(100)
  tanggal         DateTime       @db.Date
  created_by      Int
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  media_type      String?        @default("image") @db.VarChar(20)
  creator         User           @relation("FotoCreatedBy", fields: [created_by], references: [id])

  @@index([organisasi_type])
  @@index([tanggal])
  @@index([created_at])
  @@map("dokumentasi_foto")
}

model Pencapaian {
  id         Int               @id @default(autoincrement())
  icon       String            @db.VarChar(100)
  nama       String            @db.VarChar(150)
  deskripsi  String
  exp_reward Int
  organisasi String            @db.VarChar(20)
  created_at DateTime          @default(now())
  penerima   SiswaPencapaian[]

  @@index([organisasi])
  @@map("pencapaian")
}

model SiswaPencapaian {
  id              Int          @id @default(autoincrement())
  pencapaian_id   Int
  tipe_anggota    TipeAnggota
  siswa_id        Int?
  anggota_osis_id Int?
  anggota_mpk_id  Int?
  tanggal         DateTime     @default(now())
  anggota_mpk     AnggotaMpk?  @relation(fields: [anggota_mpk_id], references: [id], onDelete: Cascade)
  anggota_osis    AnggotaOsis? @relation(fields: [anggota_osis_id], references: [id], onDelete: Cascade)
  pencapaian      Pencapaian   @relation(fields: [pencapaian_id], references: [id], onDelete: Cascade)
  siswa           Siswa?       @relation(fields: [siswa_id], references: [id], onDelete: Cascade)

  @@unique([pencapaian_id, siswa_id])
  @@unique([pencapaian_id, anggota_osis_id])
  @@unique([pencapaian_id, anggota_mpk_id])
  @@index([pencapaian_id])
  @@index([tipe_anggota])
  @@map("siswa_pencapaian")
}

model MateriHariIni {
  id         Int            @id @default(autoincrement())
  judul      String         @db.VarChar(255)
  deskripsi  String
  tanggal    DateTime       @db.Date
  organisasi OrganisasiType
  notulen    String?
  lokasi     String?        @db.VarChar(200)
  created_by Int
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  @@index([organisasi])
  @@index([tanggal])
  @@map("materi_hari_ini")
}

model JadwalKegiatan {
  id          Int            @id @default(autoincrement())
  judul       String         @db.VarChar(255)
  tanggal     DateTime       @db.Date
  waktu       String?        @db.VarChar(10)
  lokasi      String?        @db.VarChar(200)
  keterangan  String?
  organisasi  OrganisasiType
  wajib_hadir Boolean        @default(false)
  created_by  Int
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([organisasi])
  @@index([tanggal])
  @@map("jadwal_kegiatan")
}

model ExpLog {
  id              Int         @id @default(autoincrement())
  tipe_anggota    TipeAnggota
  siswa_id        Int?
  anggota_osis_id Int?
  anggota_mpk_id  Int?
  admin_id        Int
  exp_sebelum     Int
  exp_sesudah     Int
  selisih         Int
  alasan          String      @db.VarChar(500)
  organisasi      String      @db.VarChar(20)
  created_at      DateTime    @default(now())

  @@index([tipe_anggota])
  @@index([siswa_id])
  @@index([anggota_osis_id])
  @@index([anggota_mpk_id])
  @@index([admin_id])
  @@index([created_at])
  @@map("exp_log")
}

enum Role {
  administrator
  admin_programming
  admin_english
  admin_osis_mpk
}

enum OrganisasiType {
  programming
  english
  osis
  mpk
}

enum StatusAbsensi {
  hadir
  tidak_hadir
  izin
  sakit
  kas_saja
}

enum AksiLog {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum StatusWawancara {
  SCHEDULED
  ACTIVE
  SELESAI
  DIBATALKAN
}

enum StatusAntrian {
  MENUNGGU
  WAWANCARA
  SELESAI_WAWANCARA
}

enum StatusValidasiScan {
  SAH
  SAH_DICURIGAI
  DITOLAK_VPN
  TIDAK_SAH
}

enum StatusIpScan {
  NORMAL
  VPN_INDONESIA
  VPN_LUAR_NEGERI
  TIDAK_DIKETAHUI
}

enum HasilWawancara {
  DITERIMA
  DITOLAK
  DIPERTIMBANGKAN
  LOLOS
  TIDAK_LOLOS
  PENDING
}

enum KeteranganWawancara {
  AKTIF
  KURANG_AKTIF
}

enum UpdateType {
  update
  pengumuman
  perbaikan
}

enum TipeAnggota {
  siswa
  anggota_osis
  anggota_mpk
}

model EmailLog {
  id               Int            @id @default(autoincrement())
  subject          String         @db.VarChar(255)
  recipientEmail   String         @db.VarChar(150)
  recipientName    String         @db.VarChar(100)
  emailType        String         @db.VarChar(50)  // "pertemuan", "rapat", "masalah", "pembahasan"
  organizationType OrganisasiType
  content          String         @db.Text
  
  tipe_anggota     TipeAnggota
  siswa_id         Int?
  anggota_osis_id  Int?
  anggota_mpk_id   Int?

  siswa            Siswa?         @relation("SiswaEmailLogs", fields: [siswa_id], references: [id], onDelete: Cascade)
  anggota_osis     AnggotaOsis?   @relation("OsisEmailLogs", fields: [anggota_osis_id], references: [id], onDelete: Cascade)
  anggota_mpk      AnggotaMpk?    @relation("MpkEmailLogs", fields: [anggota_mpk_id], references: [id], onDelete: Cascade)
  
  admin_id         Int
  admin            User           @relation("AdminEmailLogs", fields: [admin_id], references: [id], onDelete: Cascade)
  
  status           String         @default("sent") @db.VarChar(20) // "sent", "failed"
  error_message    String?        @db.Text
  
  sent_at          DateTime?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  @@index([siswa_id])
  @@index([anggota_osis_id])
  @@index([anggota_mpk_id])
  @@index([admin_id])
  @@index([status])
  @@index([created_at])
  @@map("email_logs")
}

model EmailTemplate {
  id               Int            @id @default(autoincrement())
  organizationType OrganisasiType
  emailType        String         @db.VarChar(50)
  subject          String         @db.Text
  bodyTemplate     String         @db.Text // HTML dengan {{placeholder}}
  description      String?        @db.Text
  isActive         Boolean        @default(true)
  created_by       Int
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  
  @@unique([organizationType, emailType])
  @@index([isActive])
  @@map("email_templates")
}

model EmailImportLog {
  id               Int            @id @default(autoincrement())
  filename         String         @db.VarChar(255)
  totalRows        Int
  successRows      Int
  failureRows      Int
  organizationType OrganisasiType
  admin_id         Int
  admin            User           @relation("AdminImportLogs", fields: [admin_id], references: [id], onDelete: Cascade)
  errors           String         @db.Text // JSON array
  status           String         @default("completed") @db.VarChar(20)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  
  @@index([admin_id])
  @@index([status])
  @@map("email_import_logs")
}
