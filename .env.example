# ==========================================
# FILE CONTOH UNTUK DEPLOYMENT (LOKAL & VPS)
# ==========================================
# Ganti nilai-nilai di bawah ini dengan password Anda sendiri
# lalu simpan file ini dengan nama: .env

# ─── Supabase Configuration ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"
SUPABASE_SECRET_KEY="your-secret-key"

# ─── Prisma Database connection ──────────────────────────────
# Gunakan pooled URL untuk DATABASE_URL dan direct URL untuk DIRECT_URL
DATABASE_URL="postgres://postgres.your-ref:your-pass@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://postgres.your-ref:your-pass@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Supabase PostgreSQL Details ─────────────────────────────
POSTGRES_URL="your-postgres-url"
POSTGRES_PRISMA_URL="your-postgres-prisma-url"
POSTGRES_URL_NON_POOLING="your-postgres-url-non-pooling"
POSTGRES_USER="postgres"
POSTGRES_HOST="db.your-ref.supabase.co"
POSTGRES_PASSWORD="your-password"
POSTGRES_DATABASE="postgres"

# ─── Neon PostgreSQL Configuration ───────────────────────────
# Gunakan ini untuk migrasi ke Neon Data Editor
NEON_DATABASE_URL="postgresql://neondb_owner:your-pass@ep-your-host-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
NEON_DIRECT_URL="postgresql://neondb_owner:your-pass@ep-your-host.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── App Secret ──────────────────────────────────────────────
JWT_SECRET="ganti-dengan-secret-anda-yang-panjang-dan-aman-sekali-12345"
