# ==========================================
# FILE CONTOH UNTUK DEPLOYMENT (LOKAL & VPS)
# ==========================================
# Ganti nilai-nilai di bawah ini dengan password Anda sendiri
# lalu simpan file ini dengan nama: .env

# Konfigurasi MySQL (untuk docker-compose)
MYSQL_ROOT_PASSWORD=password_root_rahasia
MYSQL_DATABASE=ekskul_db
MYSQL_USER=ekskul_user
MYSQL_PASSWORD=password_user_rahasia

# URL Database untuk Prisma di dalam container
# (PENTING: Jangan ubah "mysql:3306", ubah saja username dan passwordnya)
DATABASE_URL="mysql://ekskul_user:password_user_rahasia@mysql:3306/ekskul_db"

# Secret Key untuk Auth
JWT_SECRET="ganti-dengan-secret-anda-yang-panjang-dan-aman-sekali-12345"
